{"id":1,"name":"CLON 2","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":23,"switch2Valid":true,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"$ijon++","direction":6,"pattern":1,"characterIndex":0},"list":[{"code":230,"indent":0,"parameters":[60]},{"code":101,"indent":0,"parameters":["Actor1+++++",0,0,2,"Ijon Tichy"]},{"code":401,"indent":0,"parameters":["I tell you, it was in your left pocket! "]},{"code":401,"indent":0,"parameters":["Or perhaps the right one of your tomorrow-self. "]},{"code":101,"indent":0,"parameters":["Actor1+++++",0,0,2,"Ijon Tichy"]},{"code":401,"indent":0,"parameters":["How am I supposed to keep track of your "]},{"code":401,"indent":0,"parameters":["sartorial negligence?"]},{"code":230,"indent":0,"parameters":[20]},{"code":101,"indent":0,"parameters":["Actor1+++++++",0,0,2,"Ijon Tichy"]},{"code":401,"indent":0,"parameters":["My negligence? You were the one insisting that "]},{"code":401,"indent":0,"parameters":["the autopilot 'understood' your soul."]},{"code":101,"indent":0,"parameters":["Actor1+++++++",0,0,2,"Ijon Tichy"]},{"code":401,"indent":0,"parameters":["Now the ship is headed straight for a nebula "]},{"code":401,"indent":0,"parameters":["shaped like a teapot and we lack the security "]},{"code":401,"indent":0,"parameters":["code to stop it!"]},{"code":230,"indent":0,"parameters":[20]},{"code":101,"indent":0,"parameters":["Actor1+++++",0,0,2,"Ijon Tichy"]},{"code":401,"indent":0,"parameters":["It’s a very distinguished nebula! And I didn't "]},{"code":401,"indent":0,"parameters":["lose the code; I simply deposited it in a place "]},{"code":401,"indent":0,"parameters":["so secure that even I, in my infinite wisdom, "]},{"code":401,"indent":0,"parameters":["cannot find it."]},{"code":230,"indent":0,"parameters":[20]},{"code":101,"inden